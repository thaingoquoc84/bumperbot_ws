```xml
<launch>

  <!-- ===== KHAI BÁO THAM SỐ ===== -->
  <arg name="use_sim_time" default="True"/>
  <arg name="use_simple_controller" default="True"/>

  <!-- THÊM 2 THAM SỐ BỊ THIẾU -->
  <arg name="wheel_radius" default="0.033"/>
  <arg name="wheel_separation" default="0.17"/>


  <!-- ===== joint_state_broadcaster ===== -->
  <node pkg="controller_manager"
        exec="spawner"
        name="joint_state_broadcaster_spawner"
        output="screen"
        args="joint_state_broadcaster --controller-manager /controller_manager" />


  <!-- ===== bumperbot_controller (KHÔNG dùng khi simple = True) ===== -->
  <node pkg="controller_manager"
        exec="spawner"
        name="wheel_controller_spawner"
        output="screen"
        args="bumperbot_controller --controller-manager /controller_manager"
        unless="$(var use_simple_controller)" />


  <!-- ===== SIMPLE CONTROLLER (PYTHON ONLY) ===== -->
  <group if="$(var use_simple_controller)">

    <!-- spawn controller -->
    <node pkg="controller_manager"
          exec="spawner"
          name="simple_velocity_controller_spawner"
          output="screen"
          args="simple_velocity_controller --controller-manager /controller_manager" />

    <!-- CHỈ CHẠY PYTHON -->
    <node pkg="bumperbot_controller"
          exec="simple_controller.py"
          name="simple_controller_py"
          output="screen">

      <param name="wheel_radius" value="$(var wheel_radius)"/>
      <param name="wheel_separation" value="$(var wheel_separation)"/>
      <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>

  </group>

</launch>
```
