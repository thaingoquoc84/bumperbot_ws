<launch>

  <!-- Arguments -->
  <arg name="use_sim_time" default="true"/>
  <arg name="map_name" default="small_house"/>

  <!-- Map server node -->
  <node pkg="nav2_map_server"
        exec="map_server"
        name="map_server"
        output="screen">

    <param name="use_sim_time" value="$(var use_sim_time)"/>
    
    <param name="yaml_filename" 
           value="$(find-pkg-share bumperbot_mapping)/maps/$(var map_name)/map.yaml"/>

  </node>

  <node
    pkg="nav2_lifecycle_manager"
    exec="lifecycle_manager"
    name="lifecycle_manager_localization"
    output="screen">

    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="autostart" value="true"/>

    <!-- node_names là list -->
    <param name="node_names" value="['map_server']"/>

  </node>


</launch>